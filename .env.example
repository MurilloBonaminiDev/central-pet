# =============================================================================
# Central Pet — Environment Variables (example)
# Copy to .env and fill values. Never commit real secrets.
# =============================================================================

# --- Runtime ---
APP_ENV=development
APP_NAME=Central Pet
APP_DEBUG=true
TZ=America/Sao_Paulo

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Central Pet

# --- Backend ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Database ---
# Local-dev without Docker (SQLite):
DATABASE_URL=sqlite:///./central_pet.db
# Production / Docker Postgres:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=central_pet
# POSTGRES_PASSWORD=change_me_strong_password
# POSTGRES_DB=central_pet
# DATABASE_URL=postgresql+psycopg://central_pet:change_me_strong_password@localhost:5432/central_pet

# --- Redis (optional for auth; use memory:// when Redis is unavailable) ---
REDIS_URL=memory://
# REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Multi-tenant ---
# Reserved for future tenant resolution strategy (header / subdomain)
TENANT_HEADER=X-Tenant-Id
